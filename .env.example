# ─────────────────────────────────────────────────────────────────────────────
# UTMS — Environment Variables
# Copy this file to .env and fill in the required values.
# .env is git-ignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | production

# ── Database (overridden by docker-compose for containerised runs) ────────────
DATABASE_URL=postgresql+asyncpg://utms:utms@localhost:5432/utms
DATABASE_URL_SYNC=postgresql+psycopg2://utms:utms@localhost:5432/utms

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=utms-documents
MINIO_SECURE=false

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate a key pair with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then copy the PEM content here, replacing newlines with \n:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n<paste private key here>\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n<paste public key here>\n-----END PUBLIC KEY-----

# ── App URL (used in email links) ────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000

# ── Email (Gmail SMTP with App Password) ─────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account.
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
#    (16 chars, e.g. "abcd efgh ijkl mnop"). Spaces are OK — they are stripped
#    in code before authenticating.
# 3. Paste it as SMTP_PASSWORD in your local .env (NEVER commit the real value).
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.account@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# The "From" address Gmail will rewrite to your authenticated mailbox.
# Use a friendly name + your Gmail address, e.g. "UTMS <your.account@gmail.com>".
FROM_EMAIL=UTMS <your.account@gmail.com>

# Frontend URL — used to build the verification / reset links inside the email.
FRONTEND_URL=http://localhost:5173

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
